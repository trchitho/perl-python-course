<script>(function(){var t=localStorage.getItem("token"),r=localStorage.getItem("role");function s(id,on){var el=document.getElementById(id); if(!el) return; el.style.display=on?"inline-block":"none";} if(t){s("heroLogin",false); s("heroSignup",false); s("goDashStudent", r==="student"); s("goDashTeacher", r==="teacher"); s("goDashAdmin", r==="admin");} else {s("heroLogin",true); s("heroSignup",true); s("goDashStudent", true); s("goDashTeacher", true); s("goDashAdmin", true);} })();</script>
