# ============================================
# DATABASE CONFIGURATION
# ============================================

# Database type (mssql or mysql)
DB_TYPE=mssql

# SQL Server Configuration
DB_SERVER=localhost\SQLEXPRESS
DB_NAME=ELearningDB
DB_TRUSTED_CONNECTION=yes

# If using SQL Authentication (comment out if using Windows Auth)
# DB_USER=your_username
# DB_PASSWORD=your_password
# DB_TRUSTED_CONNECTION=no

# ============================================
# JWT AUTHENTICATION
# ============================================

# Secret key for JWT tokens (CHANGE THIS IN PRODUCTION!)
JWT_SECRET_KEY=your-super-secret-key-change-this-in-production

# ============================================
# REDIS CACHE (Optional)
# ============================================

# Redis URL (comment out if not using Redis)
REDIS_URL=redis://localhost:6379/0

# ============================================
# GOOGLE GEMINI AI (Optional)
# ============================================

# Gemini API Key for chatbot (leave empty if not using)
GEMINI_API_KEY=

# ============================================
# EMAIL CONFIGURATION (Optional)
# ============================================

# Enable/disable email features
SMTP_ENABLED=false

# SMTP settings for sending emails
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM_EMAIL=your-email@gmail.com
SMTP_FROM_NAME=E-Learning Platform

# Frontend URL (for email links)
FRONTEND_URL=http://localhost:5173

# ============================================
# GOOGLE OAUTH 2.0 (Optional)
# ============================================

# Enable/disable Google OAuth
GOOGLE_OAUTH_ENABLED=false

# Google OAuth credentials (get from https://console.cloud.google.com/)
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret
GOOGLE_REDIRECT_URI=http://localhost:5000/api/auth/google/callback

# ============================================
# CLOUDINARY (Video/Image Hosting)
# ============================================

# Get these from https://cloudinary.com/console
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# If not configured, will use local storage

# ============================================
# APPLICATION SETTINGS
# ============================================

# Flask environment (development or production)
FLASK_ENV=development

# Debug mode (True or False)
DEBUG=True

# Upload folder path (fallback if Cloudinary not configured)
UPLOAD_FOLDER=uploads

# Maximum upload size in MB
MAX_UPLOAD_SIZE=100
